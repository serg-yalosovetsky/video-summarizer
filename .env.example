# User profile used in summaries and meeting todos
USER_PRIMARY_NAME=Сергей
USER_ALIASES=Сергей,Сергій,Serhii

# Hugging Face access for gated models
HF_TOKEN=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_CLEAN_MODEL=gemma4:e4b
FRAME_MODEL=gemma4:e4b
OLLAMA_TIMEOUT_SECONDS=900
OLLAMA_SUMMARY_MAX_TOKENS=1024
OLLAMA_CLEAN_MAX_TOKENS=4096

# Speech / diarization
CANARY_MODEL=nvidia/canary-1b-v2
CANARY_DEVICE=cuda
CANARY_SEGMENT_BATCH_SIZE=8
PYANNOTE_MODEL=pyannote/speaker-diarization-3.1
PYANNOTE_DEVICE=auto

# Frame analysis / limits
FRAME_TIMESTAMPS=1,2,5,10
MAX_FRAMES=20
MAX_VISUAL_CONTEXT_CHARS=2000
MAX_UPLOAD_MB=500

# Paths
LOCAL_TMP_DIR=tmp
ARTIFACTS_DIR=artifacts
PROJECT_MEMORY_PATH=.omx/project-memory.json

# Notifications
NTFY_TOPIC=video_summarizer
# Optional explicit override instead of NTFY_TOPIC
# NTFY_URL=https://ntfy.sh/video_summarizer
